# =============================================================================
# Projeto Cidadão — Variáveis de ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
# Gere uma chave JWT segura com:
#   openssl rand -hex 32
# =============================================================================

# ----- Aplicação -----
APP_ENV=production
APP_DEBUG=false
APP_NAME=Projeto Cidadão
APP_URL=http://localhost:8000

# ----- Segurança (TROCAR!) -----
JWT_SECRET=mude-esta-chave-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ----- Banco de dados -----
POSTGRES_DB=projetocidadao
POSTGRES_USER=cidadao
POSTGRES_PASSWORD=mudar123
DB_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- API -----
API_PORT=8000

# ----- Nginx -----
HTTP_PORT=80
HTTPS_PORT=443

# ----- Telegram Bot (opcional) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ----- E-mail (opcional, para notificações) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@projetocidadao.org

# ----- Logs -----
LOG_LEVEL=INFO
