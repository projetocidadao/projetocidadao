# --- Database ---
DATABASE_URL=postgresql+asyncpg://projetocidadao:changeme@localhost:5432/projetocidadao
DATABASE_URL_SYNC=postgresql+psycopg2://projetocidadao:changeme@localhost:5432/projetocidadao

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=changeme-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080  # 7 dias

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Storage (S3-compatible) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=projetocidadao
S3_REGION=us-east-1

# --- Telegram Bot (notificações) ---
TELEGRAM_BOT_TOKEN=
