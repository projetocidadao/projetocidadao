# App
APP_NAME=Projeto Cidadão API
APP_ENV=development
DEBUG=true

# Database (asyncpg para o app, psycopg2 para o Alembic)
DATABASE_URL=postgresql+asyncpg://projetocidadao:changeme@localhost:5432/projetocidadao
DATABASE_URL_SYNC=postgresql+psycopg2://projetocidadao:changeme@localhost:5432/projetocidadao
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=changeme-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006"]

# LGPD
LGPD_ENABLED=true
