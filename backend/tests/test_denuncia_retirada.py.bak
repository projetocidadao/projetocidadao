"""
Testes do modelo de retirada/cancelamento de denuncias (issue #9).
"""
import pytest
from httpx import AsyncClient
from sqlalchemy.ext.asyncio import AsyncSession

from src.db.models.denuncia import Denuncia
from src.db.models.usuario import Usuario
from src.db.models.enums import UserRole, CategoriaDenuncia, StatusDenuncia
from src.core.security import hash_senha, criar_access_token


def payload_criar(titulo="Denuncia teste retirada", area_id=1, anonima=False):
    return {
        "titulo": titulo,
        "descricao": "Descricao detalhada da denuncia para o teste do modelo de retirada automatizado.",
        "categoria": "outro",
        "area_id": area_id,
        "anonima": anonima,
        "publica": True,
    }


async def criar_denuncia(client, headers, **kwargs):
    payload = payload_criar(**kwargs)
    resp = await client.post("/api/denuncias", json=payload, headers=headers)
    assert resp.status_code == 201, f"Falha ao criar: {resp.text}"
    return resp.json()


@pytest.mark.asyncio
async def test_01_autor_pede_retirada_sucesso(
    client: AsyncClient, auth_headers_comum, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id)
    resp = await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Resolvi o problema por conta propria."},
        headers=auth_headers_comum,
    )
    assert resp.status_code == 200, resp.text
    data = resp.json()
    assert data["pedido_retirada_em"] is not None
    assert data["pedido_retirada_justificativa"] == "Resolvi o problema por conta propria."
    assert data["status_remocao"] is None
    assert data["autor_id"] is not None


@pytest.mark.asyncio
async def test_02_nao_autor_nao_pode_pedir_retirada(
    client: AsyncClient, auth_headers_comum, area_exemplo, session: AsyncSession
):
    outro = Usuario(
        email="outro@test.org", nome="Outro",
        senha_hash=hash_senha("outro12345"),
        role=UserRole.CIDADAO, verificado=True, ativo=True,
    )
    session.add(outro)
    await session.commit()
    await session.refresh(outro)
    headers_outro = {"Authorization": f"Bearer {criar_access_token(subject=str(outro.id))}"}

    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id)
    resp = await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Vou tentar tirar a dos outros."},
        headers=headers_outro,
    )
    assert resp.status_code == 403, resp.text
    assert "autor" in resp.json()["detail"].lower()


@pytest.mark.asyncio
async def test_03_pedir_retirada_duas_vezes_conflito(
    client: AsyncClient, auth_headers_comum, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id)
    r1 = await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Primeira tentativa."}, headers=auth_headers_comum,
    )
    assert r1.status_code == 200
    r2 = await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Segunda tentativa."}, headers=auth_headers_comum,
    )
    assert r2.status_code == 409, r2.text


@pytest.mark.asyncio
async def test_04_moderador_confirma_retirada_anonimiza(
    client: AsyncClient, auth_headers_comum, auth_headers_moderador, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id, titulo="Vou pedir retirada")
    autor_id_original = d["autor_id"]
    descricao_original = d["descricao"]

    await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Pedi demissao e nao quero mais rastrear."},
        headers=auth_headers_comum,
    )

    resp = await client.post(
        f"/api/denuncias/{d['id']}/decisao-retirada",
        json={"decisao": "confirmar", "motivo_decisao": "Pedido legitimo, sem coacao."},
        headers=auth_headers_moderador,
    )
    assert resp.status_code == 200, resp.text
    data = resp.json()
    assert data["autor_id"] is None
    assert data["anonima"] is True
    assert data["status_remocao"] == "retirada_pelo_autor"
    assert data["removida_em"] is not None
    assert data["removida_por"] is not None
    assert data["motivo_remocao"] == "Pedido legitimo, sem coacao."
    assert descricao_original in data["descricao"]
    assert "AVISO: Esta denuncia foi retirada" in data["descricao"]


@pytest.mark.asyncio
async def test_05_moderador_recusa_retirada_coacao(
    client: AsyncClient, auth_headers_comum, auth_headers_moderador, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id, titulo="Suspeita de coacao")
    autor_id_original = d["autor_id"]

    await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Me ameacaram, preciso tirar."},
        headers=auth_headers_comum,
    )

    resp = await client.post(
        f"/api/denuncias/{d['id']}/decisao-retirada",
        json={"decisao": "recusar", "motivo_decisao": "Evidencia de coacao. Interesse publico."},
        headers=auth_headers_moderador,
    )
    assert resp.status_code == 200, resp.text
    data = resp.json()
    assert data["status_remocao"] == "cancelada_por_coacao"
    assert data["autor_id"] == autor_id_original


@pytest.mark.asyncio
async def test_06_decidir_sem_pedido_previo(
    client: AsyncClient, auth_headers_comum, auth_headers_moderador, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id)
    resp = await client.post(
        f"/api/denuncias/{d['id']}/decisao-retirada",
        json={"decisao": "confirmar", "motivo_decisao": "Vou decidir sem pedido."},
        headers=auth_headers_moderador,
    )
    assert resp.status_code == 400, resp.text
    assert "pedido" in resp.json()["detail"].lower()


@pytest.mark.asyncio
async def test_07_cidadao_nao_pode_decidir(
    client: AsyncClient, auth_headers_comum, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id)
    await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Pedido normal."}, headers=auth_headers_comum,
    )
    resp = await client.post(
        f"/api/denuncias/{d['id']}/decisao-retirada",
        json={"decisao": "confirmar", "motivo_decisao": "Auto-confirmacao."},
        headers=auth_headers_comum,
    )
    assert resp.status_code == 403, resp.text


@pytest.mark.asyncio
async def test_08_admin_lista_pedidos_pendentes(
    client: AsyncClient, auth_headers_comum, auth_headers_admin, area_exemplo
):
    d1 = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id, titulo="Pedido 1")
    await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id, titulo="Sem pedido")

    await client.post(
        f"/api/denuncias/{d1['id']}/pedido-retirada",
        json={"justificativa": "Quero retirar."}, headers=auth_headers_comum,
    )

    resp = await client.get(
        "/api/admin/pedidos-retirada-pendentes", headers=auth_headers_admin,
    )
    assert resp.status_code == 200, resp.text
    data = resp.json()
    assert isinstance(data, list)
    ids = [item["id"] for item in data]
    assert d1["id"] in ids


@pytest.mark.asyncio
async def test_09_decidir_duas_vezes_conflito(
    client: AsyncClient, auth_headers_comum, auth_headers_moderador, area_exemplo
):
    d = await criar_denuncia(client, auth_headers_comum, area_id=area_exemplo.id)
    await client.post(
        f"/api/denuncias/{d['id']}/pedido-retirada",
        json={"justificativa": "Pedido normal."}, headers=auth_headers_comum,
    )
    r1 = await client.post(
        f"/api/denuncias/{d['id']}/decisao-retirada",
        json={"decisao": "confirmar", "motivo_decisao": "OK primeira."},
        headers=auth_headers_moderador,
    )
    assert r1.status_code == 200
    r2 = await client.post(
        f"/api/denuncias/{d['id']}/decisao-retirada",
        json={"decisao": "recusar", "motivo_decisao": "Tentando de novo."},
        headers=auth_headers_moderador,
    )
    assert r2.status_code == 409, r2.text
