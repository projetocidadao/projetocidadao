@pytest.fixture
def token_comum(usuario_comum) -> str:
    return criar_access_token(subject=str(usuario_comum.id))


@pytest.fixture
def token_admin(usuario_admin) -> str:
    return criar_access_token(subject=str(usuario_admin.id))


@pytest.fixture
