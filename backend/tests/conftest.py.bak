@pytest_asyncio.fixture
async def multiplas_denuncias(session: AsyncSession, usuario_comum, area_exemplo):
    denuncias = []
    for i in range(5):
        d = Denuncia(
            titulo=f"Denuncia {i+1}", descricao=f"Descricao {i+1}",
            categoria=CategoriaDenuncia.SAUDE.value,
            status=StatusDenuncia.AGUARDANDO, publica=True,
            autor_id=usuario_comum.id, area_id=area_exemplo.id,
            municipio="Rio", estado="RJ", codigo_rastreio=f"PC-TEST{i:04d}",
        )
        session.add(d)
        denuncias.append(d)
    await session.commit()
    for d in denuncias:
        await session.refresh(d)
    return denuncias
